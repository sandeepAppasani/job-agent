# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# RapidAPI Key for JSearch (get from https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here

# LinkedIn Credentials (for automated applications)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# Google Sheets Configuration
# Sheet name to track applications
GOOGLE_SHEET_NAME=Job Applications Tracker
# Path to your Google service account credentials JSON
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json

# Resume Configuration
RESUME_DIR=Resume
RESUME_FILENAME=Sandeep Appasani_Resume.docx

# Job Search Configuration (comma-separated)
JOB_ROLES=QA Engineer,Test Engineer,Data Engineer,Azure Data Engineer,AI Engineer,SDET,Automation Tester
JOB_LOCATION=United States
JOB_REMOTE=true

# Application Settings
AUTO_APPLY_ENABLED=false
MAX_JOBS_PER_RUN=20
APPLICATIONS_DIR=applications
